<Window x:Class="NativeAreaScreenshot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定 - Area Screenshot" Height="250" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="保存先フォルダー:" FontWeight="Bold" Margin="0,0,0,5" Grid.Row="0"/>
        
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSaveFolder" Height="25" VerticalContentAlignment="Center" IsReadOnly="True" Background="#F0F0F0"/>
            <Button x:Name="BtnBrowse" Content="参照..." Width="80" Height="25" Margin="10,0,0,0" Grid.Column="1" Click="BtnBrowse_Click"/>
        </Grid>
        
        <TextBlock Grid.Row="2" TextWrapping="Wrap" Foreground="#666" FontSize="11">
            ヒント: ここで指定したフォルダーにスクリーンショットが自動でPNG保存されます。
        </TextBlock>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="キャンセル" Width="80" Height="30" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="保存" Width="80" Height="30" Background="#00a8ff" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
