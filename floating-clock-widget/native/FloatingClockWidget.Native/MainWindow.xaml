<Window x:Class="FloatingClockWidget.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floating Clock Widget"
        Width="360"
        Height="220"
        MinWidth="280"
        MinHeight="160"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Border x:Name="SceneBackground"
                Margin="8"
                CornerRadius="26"
                Opacity="0.95">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2A102536" Offset="0.0" />
                    <GradientStop Color="#29080D18" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border x:Name="PanelBorder"
                Margin="16"
                CornerRadius="22"
                BorderThickness="1"
                BorderBrush="#24FFFFFF"
                Background="#DD0B0B12">
            <Border.Effect>
                <DropShadowEffect x:Name="PanelShadowEffect"
                                  Color="#70000000"
                                  BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.90" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="PanelScaleTransform" />
                    <TranslateTransform x:Name="PanelTranslateTransform" />
                </TransformGroup>
            </Border.RenderTransform>

            <Grid Margin="12,10,12,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="Transparent"
                      MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="BrandText"
                               Text="Floating Clock"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#FF00E5FF"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="VersionText"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#FF9CB6C9" />
                        <Button x:Name="LiteButton"
                                Width="58"
                                Height="28"
                                Margin="0,0,6,0"
                                Content="LITE OFF"
                                Click="LiteButton_Click" />
                        <Button x:Name="ImportButton"
                                Width="62"
                                Height="28"
                                Margin="0,0,6,0"
                                Content="Import"
                                Click="ImportButton_Click" />
                        <Button Width="48"
                                Height="28"
                                Content="Exit"
                                Click="ExitButton_Click" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="0,6,0,0">
                    <TextBlock x:Name="TimeText"
                               FontSize="48"
                               FontWeight="SemiBold"
                               Foreground="#FFF7FDFF"
                               Text="00:00:00"
                               TextOptions.TextFormattingMode="Display" />
                    <TextBlock x:Name="DateText"
                               Margin="1,0,0,0"
                               FontSize="14"
                               Foreground="#FF9CB6C9"
                               Text="0000-00-00" />
                </StackPanel>

                <DockPanel Grid.Row="2"
                           Margin="0,8,0,0">
                    <TextBlock Text="Theme"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#FF9CB6C9" />
                    <ComboBox x:Name="ThemeComboBox"
                              MinHeight="32"
                              VerticalAlignment="Center"
                              SelectionChanged="ThemeComboBox_SelectionChanged"
                              DisplayMemberPath="DisplayLabel" />
                </DockPanel>

                <TextBlock x:Name="StatusText"
                           Grid.Row="3"
                           Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="#FF9CB6C9"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Border x:Name="PulseRing"
                Margin="14"
                CornerRadius="26"
                BorderThickness="2"
                BorderBrush="#8800E5FF"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <ScaleTransform x:Name="PulseScaleTransform" />
            </Border.RenderTransform>
        </Border>
    </Grid>
</Window>
