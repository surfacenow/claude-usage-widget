{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://floating-clock-widget/schemas/manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "requiredAppVersion",
    "author",
    "preview",
    "entryCss",
    "entryTokens"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "requiredAppVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "preview": {
      "type": "string",
      "minLength": 1
    },
    "entryCss": {
      "type": "string",
      "minLength": 1
    },
    "entryTokens": {
      "type": "string",
      "minLength": 1
    }
  }
}
